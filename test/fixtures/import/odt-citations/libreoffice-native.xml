<?xml version="1.0" encoding="UTF-8"?>
<!--
  Synthetic ODT content.xml fragment — LibreOffice native bibliography marks.

  Format: <text:bibliography-mark> with all bibliographic data stored as XML
  attributes directly on the element.  This is the format used by
  LibreOffice Writer's built-in bibliography tool (Insert → Table of
  Contents and Index → Bibliography Entry).

  The element is self-contained: no external data file or citation manager
  plugin is required.  The text content of the element is the displayed
  citation label.

  Supported bibliography types from the ODF 1.2 spec:
    article, book, booklet, conference, inbook, incollection, inproceedings,
    journal, manual, mastersthesis, misc, phdthesis, proceedings, techreport,
    unpublished, www, email, custom1–custom5.

  Three entries are included:
    Jones2019   — article (journal article)
    Smith2020   — book
    Doe2018     — phdthesis
-->
<office:document-content
    xmlns:office="urn:oasis:names:tc:opendocument:xmlns:office:1.0"
    xmlns:text="urn:oasis:names:tc:opendocument:xmlns:text:1.0"
    xmlns:style="urn:oasis:names:tc:opendocument:xmlns:style:1.0">

  <office:body>
    <office:text>

      <!-- ============================================================
           Paragraph 1 — article citation
           identifier: Jones2019
           All common article fields demonstrated.
           ============================================================ -->
      <text:p text:style-name="Text Body">
        <text:span>As shown in </text:span>
        <text:bibliography-mark
            text:bibliography-type="article"
            text:identifier="Jones2019"
            text:author="Jones, Alice"
            text:title="Research Methods in Ecology"
            text:journal="Science Journal"
            text:year="2019"
            text:volume="12"
            text:number="3"
            text:pages="45-67"
            text:doi="10.1000/xyz123"
            text:url="https://example.org/jones2019"
            text:issn="1234-5678"
            text:note="Landmark study on field methods">Jones2019</text:bibliography-mark>
        <text:span xml:space="preserve">, the results confirm the hypothesis.</text:span>
      </text:p>

      <!-- ============================================================
           Paragraph 2 — book citation
           identifier: Smith2020
           Demonstrates publisher, address, edition, and ISBN fields.
           Also exercises semicolon-separated multiple authors.
           ============================================================ -->
      <text:p text:style-name="Text Body">
        <text:span>According to </text:span>
        <text:bibliography-mark
            text:bibliography-type="book"
            text:identifier="Smith2020"
            text:author="Smith, John; Doe, Jane"
            text:title="Introduction to Testing"
            text:year="2020"
            text:publisher="Test Press"
            text:address="New York"
            text:edition="3"
            text:isbn="978-3-16-148410-0"
            text:url="https://example.org/smith2020">Smith2020</text:bibliography-mark>
        <text:span xml:space="preserve">, this approach is well established.</text:span>
      </text:p>

      <!-- ============================================================
           Paragraph 3 — phdthesis citation
           identifier: Doe2018
           Demonstrates school → institution mapping and report-type field.
           ============================================================ -->
      <text:p text:style-name="Text Body">
        <text:span>This was first described in </text:span>
        <text:bibliography-mark
            text:bibliography-type="phdthesis"
            text:identifier="Doe2018"
            text:author="Doe, Robert"
            text:title="Experimental Methods in Software Engineering"
            text:year="2018"
            text:school="University of Example"
            text:address="Example City"
            text:report-type="PhD thesis"
            text:annote="Available from institutional repository">Doe2018</text:bibliography-mark>
        <text:span>.</text:span>
      </text:p>

      <!-- ============================================================
           Bibliography section — generated by LibreOffice.
           The <text:index-body> is regenerated when the bibliography is
           updated; the source of truth is the attributes on the
           <text:bibliography-mark> elements above.
           ============================================================ -->
      <text:bibliography text:name="Bibliography1" text:protected="false">
        <text:bibliography-source>
          <text:bibliography-entry-template
              text:bibliography-type="article"
              text:style-name="Bibliography 1">
            <text:index-entry-bibliography text:bibliography-data-field="author"/>
            <text:index-entry-span>: </text:index-entry-span>
            <text:index-entry-bibliography text:bibliography-data-field="title"/>
            <text:index-entry-span>. </text:index-entry-span>
            <text:index-entry-bibliography text:bibliography-data-field="journal"/>
            <text:index-entry-span>, </text:index-entry-span>
            <text:index-entry-bibliography text:bibliography-data-field="year"/>
          </text:bibliography-entry-template>
          <text:bibliography-entry-template
              text:bibliography-type="book"
              text:style-name="Bibliography 1">
            <text:index-entry-bibliography text:bibliography-data-field="author"/>
            <text:index-entry-span>: </text:index-entry-span>
            <text:index-entry-bibliography text:bibliography-data-field="title"/>
            <text:index-entry-span>. </text:index-entry-span>
            <text:index-entry-bibliography text:bibliography-data-field="publisher"/>
            <text:index-entry-span>, </text:index-entry-span>
            <text:index-entry-bibliography text:bibliography-data-field="year"/>
          </text:bibliography-entry-template>
        </text:bibliography-source>
        <text:index-body>
          <text:index-title>
            <text:p text:style-name="Bibliography Heading">Bibliography</text:p>
          </text:index-title>
          <text:p text:style-name="Bibliography 1">Jones, Alice: Research Methods in Ecology. Science Journal, 2019</text:p>
          <text:p text:style-name="Bibliography 1">Smith, John; Doe, Jane: Introduction to Testing. Test Press, 2020</text:p>
          <text:p text:style-name="Bibliography 1">Doe, Robert: Experimental Methods in Software Engineering. University of Example, 2018</text:p>
        </text:index-body>
      </text:bibliography>

    </office:text>
  </office:body>
</office:document-content>