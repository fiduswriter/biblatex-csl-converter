                        "text": "Effect of High-Dose Vitamin D Supplementation on All-Cause Mortality: A  Systematic Review and Meta-Analysis of Randomized Clinical Trials."
                    }
                ],
                "journaltitle": [
                    {
                        "type": "text",
                        "text": "JAMA"
                    }
                ],
                "shortjournal": [
                    {
                        "type": "text",
                        "text": "JAMA"
                    }
                ],
                "author": [
                    {
                        "family": [
                            {
