{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off",
        "noImplicitAnyLet": "off",
        "noShadowRestrictedNames": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    },
    "globals": [
      "describe",
      "it",
      "before",
      "after",
      "beforeEach",
      "afterEach",
      "expect",
      "chai"
    ]
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 5242880
  },
  "overrides": [
    {
      "includes": ["test/fixtures/**"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": ["src/i18n/locales.ts", "lib/**", "browser/**", "demo/**", "tmp/**", "*.cjs", "*.mjs"],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      }
    }
  ]
}
